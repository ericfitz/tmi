{
  "name": "tmi",
  "version": "0.0.0",
  "sideEffects": [],
  "scripts": {
    "ng": "ng",
    "start": "node server.js",
    "start:dev": "npm run build && node server.js",
    "start:prod": "npm run build:prod && NODE_ENV=production node server.js",
    "dev": "npm run build && nodemon server.js",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "cypress run-ct",
    "test:unit": "cypress run-ct",
    "lint": "ng lint",
    "typecheck": "tsc --noEmit",
    "e2e": "cypress run",
    "cypress:open": "cypress open",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "docs:generate": "compodoc -p tsconfig.json -d docs/api",
    "docs:serve": "compodoc -p tsconfig.json -d docs/api -s"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^19.2.3",
    "@angular/common": "^19.2.3",
    "@angular/compiler": "^19.2.3",
    "@angular/core": "^19.2.3",
    "@angular/forms": "^19.2.3",
    "@angular/platform-browser": "^19.2.3",
    "@angular/platform-browser-dynamic": "^19.2.3",
    "@angular/router": "^19.2.3",
    "@fortawesome/angular-fontawesome": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@maxgraph/core": "^0.16.0",
    "@ngrx/entity": "^19.0.1",
    "@ngrx/store": "^19.0.1",
    "@ngrx/store-devtools": "^19.0.1",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.1",
    "@angular-eslint/builder": "^19.3.0",
    "@angular-eslint/eslint-plugin": "^19.3.0",
    "@angular-eslint/eslint-plugin-template": "^19.3.0",
    "@angular-eslint/schematics": "^19.3.0",
    "@angular-eslint/template-parser": "^19.3.0",
    "@angular/cli": "^19.2.1",
    "@angular/compiler-cli": "^19.2.3",
    "@compodoc/compodoc": "^1.1.25",
    "@cypress/schematic": "^2.5.1",
    "@esbuild/darwin-arm64": "^0.25.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.13.13",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "cypress": "^13.6.2",
    "eslint": "^9.23.0",
    "eslint-plugin-import": "^2.31.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.2.5",
    "typescript": "~5.7.2"
  },
  "overrides": {
    "protractor": "0.0.0",
    "webdriver-manager": "0.0.0",
    "selenium-webdriver": "0.0.0",
    "webdriver-js-extender": "0.0.0",
    "tough-cookie": "^4.1.3",
    "xml2js": "^0.5.0",
    "request": "0.0.0"
  }
}
