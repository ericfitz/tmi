#!/bin/bash
# oci-env.sh.example - Template for OCI environment variables
#
# Copy this file to oci-env.sh and edit with your values.
# oci-env.sh is gitignored and will not be committed.
#
# Usage:
#   cp scripts/oci-env.sh.example scripts/oci-env.sh
#   # Edit scripts/oci-env.sh with your values
#
# This file is sourced by:
#   - scripts/run-integration-tests-oci.sh
#   - scripts/start-dev-oci.sh
#   - scripts/drop-oracle-tables.sh

# ============================================================================
# CONFIGURATION - Edit these values for your environment
# ============================================================================

# Path to Oracle Instant Client
# macOS: Usually in ~/Downloads after extraction
# Linux: Usually /usr/lib/oracle/<version>/client64/lib
export DYLD_LIBRARY_PATH="/path/to/instantclient_23_3"

# Path to Oracle wallet directory
# Extract your OCI ADB wallet zip to ./wallet directory
export TNS_ADMIN="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/wallet"

# Oracle database password
# This is the password for your OCI ADB user
export ORACLE_PASSWORD="your-password-here"

# TMI database URL — selects the Oracle ADB backend.
# The bootstrap config (config-development.yml / config-test.yml) no longer
# carries an Oracle URL; the backend is chosen entirely by this variable.
# The TNS alias (e.g. tmiadb_tp) must exist in wallet/tnsnames.ora.
# The password is supplied separately via ORACLE_PASSWORD above.
export TMI_DATABASE_URL="oracle://ADMIN@yourdb_tp"

# Oracle connect string (TNS alias from wallet/tnsnames.ora)
# Used by drop-oracle-tables.sh for admin operations.
# The _medium service level is used for admin operations (lower priority than _tp).
# export ORACLE_CONNECT_STRING="yourdb_medium"

# OCI Compartment OCID (used by container build script for repo discovery)
# export OCI_COMPARTMENT_ID="ocid1.compartment.oc1..your-compartment-ocid"

# OCI Container Registry repository OCID (optional - auto-discovered if not set)
# export CONTAINER_REPO_OCID="ocid1.containerrepo.oc1.iad.your-repo-ocid"

# ============================================================================
# END CONFIGURATION
# ============================================================================
