# TMI AWS Private Environment - Example Variables
# Copy this file to terraform.tfvars and fill in your values.
#
# IMPORTANT: This is a private deployment. After terraform apply:
# 1. The public EKS API endpoint will be automatically disabled
# 2. You must establish connectivity (VPN, bastion, private link) to manage the cluster
# 3. Configure internal DNS to resolve your TMI hostname to the internal ALB
# 4. Configure TLS via ACM and update the ALB listener

# AWS region for deployment
aws_region = "us-east-1"

# Prefix for all resource names (keep short, lowercase, alphanumeric)
name_prefix = "tmi"

# Docker image tags (update after pushing images to ECR)
tmi_image_tag   = "latest"
redis_image_tag = "latest"

# Additional environment variables for TMI server
# You MUST configure an OAuth provider and WebSocket origins for production:
# extra_env_vars = {
#   "OAUTH_PROVIDERS_GOOGLE_CLIENT_ID"     = "your-google-client-id.apps.googleusercontent.com"
#   "OAUTH_PROVIDERS_GOOGLE_CLIENT_SECRET"  = "your-google-client-secret"
#   "TMI_OAUTH_CALLBACK_URL"               = "https://tmi.internal.example.com/oauth2/callback"
#   "TMI_SERVER_TLS_SUBJECT_NAME"          = "tmi.internal.example.com"
#   "WEBSOCKET_ALLOWED_ORIGINS"            = "https://tmi-ux.internal.example.com"
#   "TMI_WEBSOCKET_INACTIVITY_TIMEOUT"     = "600"
# }

# Additional tags
# tags = {
#   Owner      = "your-name"
#   Team       = "your-team"
#   CostCenter = "your-cost-center"
# }
