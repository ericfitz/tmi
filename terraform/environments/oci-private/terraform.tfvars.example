# TMI OCI Private Deployment - Example Variables
# Copy this file to terraform.tfvars and fill in your values.
#
# This template deploys TMI with NO public internet exposure:
# - All resources in private subnets
# - Internal-only OCI load balancer
# - ADB with private endpoint (non-free tier required)
# - NAT gateway for outbound internet access
# - IAM-based deletion protection on database and vault
# - Temporary K8s API access during provisioning (auto-removed)
#
# YOU must establish connectivity (VPN, bastion, etc.) to reach the deployment.
# Estimated cost: ~$50-80/month

# ---------------------------------------------------------------------------
# Required: OCI Configuration
# ---------------------------------------------------------------------------
tenancy_ocid   = "ocid1.tenancy.oc1..<unique_id>"
compartment_id = "ocid1.compartment.oc1..<unique_id>"
region         = "us-ashburn-1"

# OCI CLI profile (from ~/.oci/config)
# oci_config_profile = "DEFAULT"

# ---------------------------------------------------------------------------
# Required: OKE Node Image
# ---------------------------------------------------------------------------
# OCID of an arm64 (aarch64) OKE node image for your region.
# Find available images:
#   oci compute image list --compartment-id <compartment> \
#     --operating-system "Oracle Linux" --shape "VM.Standard.A1.Flex" \
#     --sort-by TIMECREATED --sort-order DESC
node_image_id = "ocid1.image.oc1.<region>..<unique_id>"

# ---------------------------------------------------------------------------
# Required: Container Images
# ---------------------------------------------------------------------------
# Push images to your private OCI Container Registry first.
tmi_image_url   = "<region>.ocir.io/<namespace>/tmi/tmi:latest"
redis_image_url = "<region>.ocir.io/<namespace>/tmi/tmi-redis:latest"

# ---------------------------------------------------------------------------
# Optional: TMI-UX Frontend
# ---------------------------------------------------------------------------
# tmi_ux_enabled   = true
# tmi_ux_image_url = "<region>.ocir.io/<namespace>/tmi/tmi-ux:latest"

# ---------------------------------------------------------------------------
# Optional: Naming (defaults shown)
# ---------------------------------------------------------------------------
# name_prefix = "tmi"
# dns_label   = "tmi"

# ---------------------------------------------------------------------------
# Optional: Deployer IP for Provisioning
# ---------------------------------------------------------------------------
# Auto-detected if not set. Set this if running behind a corporate proxy
# or if auto-detection fails.
# deployer_ip = "203.0.113.50"

# ---------------------------------------------------------------------------
# Optional: OKE Node Sizing
# ---------------------------------------------------------------------------
# node_ocpus      = 2
# node_memory_gbs = 16

# ---------------------------------------------------------------------------
# Optional: Database Configuration
# ---------------------------------------------------------------------------
# db_name          = "tmidb"
# db_username      = "ADMIN"
# db_password      = "YourSecurePassword123!"  # Random if not set
# db_compute_count = 2                          # ECPUs for non-free tier ADB

# ---------------------------------------------------------------------------
# Optional: Network CIDR Blocks (defaults shown)
# ---------------------------------------------------------------------------
# vcn_cidr             = "10.0.0.0/16"
# public_subnet_cidr   = "10.0.1.0/24"
# private_subnet_cidr  = "10.0.2.0/24"
# database_subnet_cidr = "10.0.3.0/24"

# ---------------------------------------------------------------------------
# Optional: Load Balancer Bandwidth (internal LB)
# ---------------------------------------------------------------------------
# lb_min_bandwidth_mbps = 10
# lb_max_bandwidth_mbps = 100

# ---------------------------------------------------------------------------
# Optional: Secrets (if not set, random values generated)
# ---------------------------------------------------------------------------
# redis_password = "YourRedisPassword"
# jwt_secret     = "YourJWTSecret64Characters..."

# ---------------------------------------------------------------------------
# Optional: Deployer Environment Variables
# ---------------------------------------------------------------------------
# IMPORTANT for private deployments:
# - Set WEBSOCKET_ALLOWED_ORIGINS if client hostname differs from API hostname
# - Configure OAuth provider credentials
# - TMI_SERVER_TLS_SUBJECT_NAME should match your internal hostname
#
# extra_env_vars = {
#   "OAUTH_PROVIDERS_GOOGLE_CLIENT_ID"     = "your-client-id"
#   "OAUTH_PROVIDERS_GOOGLE_CLIENT_SECRET"  = "your-client-secret"
#   "TMI_SERVER_TLS_SUBJECT_NAME"          = "tmi.internal.example.com"
#   "WEBSOCKET_ALLOWED_ORIGINS"            = "https://tmi-app.internal.example.com"
# }

# ---------------------------------------------------------------------------
# Optional: Logging
# ---------------------------------------------------------------------------
# log_retention_days         = 90
# log_archive_retention_days = 365

# ---------------------------------------------------------------------------
# Optional: Alerting
# ---------------------------------------------------------------------------
# alert_email = "security-team@example.com"

# ---------------------------------------------------------------------------
# Optional: TLS / Certificate Automation
# ---------------------------------------------------------------------------
# enable_certificate_automation = true
# domain_name                   = "tmi.internal.example.com"
# dns_zone_id                   = "ocid1.dns-zone.oc1..<unique_id>"
# acme_contact_email            = "admin@example.com"
# acme_directory                = "production"

# ---------------------------------------------------------------------------
# Optional: TMI-TF-WH Webhook Analyzer
# ---------------------------------------------------------------------------
# tmi_tf_wh_enabled   = true
# tmi_tf_wh_image_url = "<region>.ocir.io/<namespace>/tmi/tmi-tf-wh:latest"

# ---------------------------------------------------------------------------
# Optional: Additional Tags
# ---------------------------------------------------------------------------
# tags = {
#   owner       = "security-team"
#   cost_center = "infosec"
# }
