# TMI AWS Production Deployment - Example Variables
# Copy this file to terraform.tfvars and fill in your values

# Required: AWS Configuration
region = "us-east-1"

# Required: Container Images
# These should be pushed to your ECR registry or a public registry
tmi_image_url   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/tmi:latest"
redis_image_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/tmi-redis:latest"

# Optional: TMI-UX Frontend
# Enable to deploy the Angular frontend alongside the API
# tmi_ux_enabled   = true
# tmi_ux_image_url = "123456789012.dkr.ecr.us-east-1.amazonaws.com/tmi-ux:latest"

# Optional: Naming (defaults shown)
name_prefix = "tmi"

# Optional: Network CIDR blocks (defaults shown)
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs  = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]
database_subnet_cidrs = ["10.0.7.0/24", "10.0.8.0/24", "10.0.9.0/24"]

# Optional: High availability NAT (default: single NAT for cost savings)
# enable_multi_az_nat = true

# Optional: Database Configuration (defaults shown)
db_name     = "tmidb"
db_username = "tmi"
# db_password = "YourSecurePassword123!"  # If not set, random password generated

# Optional: RDS instance size
# db_instance_class = "db.t4g.small"  # Upgrade from default db.t4g.micro
# db_multi_az       = true            # Enable Multi-AZ for HA

# Optional: Secrets (if not set, random values generated)
# redis_password = "YourRedisPassword"
# jwt_secret     = "YourJWTSecret"

# Optional: HTTPS with ACM Certificate + Route 53 DNS + ALB Ingress
# Enables: TLS termination, HTTP→HTTPS redirect, host-based routing, WebSocket support
# enable_certificate_automation = true
# domain_name                   = "tmiserver.example.com"
# subject_alternative_names     = ["tmi.example.com"]
# dns_zone_id                   = "Z1234567890ABC"  # Route 53 hosted zone ID
# server_domain                 = "tmiserver.example.com"  # API server hostname
# ux_domain                     = "tmi.example.com"        # Frontend hostname (requires tmi_ux_enabled=true)

# Optional: Alerting
# alert_email = "admin@example.com"

# Optional: Additional tags
tags = {
  owner = "your-team"
}

# Optional: Database protection
db_deletion_protection = true
