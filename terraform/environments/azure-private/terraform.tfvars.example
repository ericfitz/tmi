# TMI Azure Private Deployment - Example Variables
# Copy this file to terraform.tfvars and fill in your values
#
# IMPORTANT: This is a private deployment. After terraform apply:
# 1. The AKS API server is temporarily accessible from your IP during provisioning
# 2. After provisioning, public API access is removed
# 3. You must establish private connectivity (VPN, bastion, private link) to manage the cluster
# 4. Configure internal DNS and TLS for production use

# Required: Azure Configuration
subscription_id = "00000000-0000-0000-0000-000000000000"

# Optional: Region (default: eastus)
location = "eastus"

# Required: Container Images
# Push images to your ACR, then reference them here
tmi_image_url   = "tmiacr.azurecr.io/tmi:latest"
redis_image_url = "tmiacr.azurecr.io/tmi-redis:latest"

# Optional: Naming (defaults shown)
name_prefix = "tmi"

# Optional: Network CIDR blocks (defaults shown)
vnet_cidr            = "10.0.0.0/16"
aks_subnet_cidr      = "10.0.1.0/24"
database_subnet_cidr = "10.0.2.0/24"

# Optional: Allowed CIDR for private access (default: VNet CIDR)
# Set this to your organization's CIDR block
allowed_cidr = "10.0.0.0/16"

# Optional: Database Configuration (defaults shown)
db_name     = "tmi"
db_username = "tmiadmin"
# db_password = "YourSecurePassword123!"  # If not set, random password generated

# Optional: Secrets (if not set, random values generated)
# redis_password = "YourRedisPassword"
# jwt_secret     = "YourJWTSecret"

# Optional: Extra environment variables for TMI server
# IMPORTANT for private deployments: Configure WebSocket origins and TLS
# extra_env_vars = {
#   "TMI_SERVER_TLS_SUBJECT_NAME"              = "tmi.internal.example.com"
#   "WEBSOCKET_ALLOWED_ORIGINS"                = "https://tmi.internal.example.com"
#   "OAUTH_PROVIDERS_AZURE_CLIENT_ID"          = "your-client-id"
#   "OAUTH_PROVIDERS_AZURE_CLIENT_SECRET"      = "your-client-secret"
# }

# Optional: Additional tags
tags = {
  owner = "your-team"
}
