!arazzo-spectral.yaml
!asyncapi-spectral.yaml
!oas-spectral.yaml
!ruleset-all.yaml
!make-containers-dev*.sh
!Dockerfile*
!.dockerignore
!config-example.yml
!config-test-integration-pg.yml
!auth/migrations/*.sql
!.claude/settings.local.json
!package.json
!pnpm-lock.yaml

# Include subdirectories (but avoid overriding specific ignores)
!api/
!api/**
!auth/
!auth/**
!client-sdks/
!client-sdks/**
!cmd/
!cmd/**
!docs/
!docs/**
